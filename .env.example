# Copy to .env.local for development (and .env.production for deploys).
# Never commit real values — secrets live in Cloudflare/Wrangler bindings in prod.

# Neon Postgres connection string (required for any DB-touching path)
DATABASE_URL="postgresql://user:password@host.neon.tech/blu_crm?sslmode=require"

# Better Auth — generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=""
# Canonical app URL (callbacks/redirects)
BETTER_AUTH_URL="http://localhost:3000"

# Inlined into the client bundle at build time (auth client base URL)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Public base URL of the R2 bucket; unset = local-dev fallback behaviour
# NEXT_PUBLIC_R2_PUBLIC_URL=""

# AI assistant (FR-7) — required once the assistant ships (M4)
# ANTHROPIC_API_KEY=""

# Microsoft 365 (Entra ID) SSO — required once the Entra app is registered
# MICROSOFT_CLIENT_ID=""
# MICROSOFT_CLIENT_SECRET=""
# MICROSOFT_TENANT_ID=""
