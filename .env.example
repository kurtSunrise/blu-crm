# Copy to .env.local for development (and .env.production for deploys).
# Never commit real values — secrets live in Cloudflare/Wrangler bindings in prod.

# Neon Postgres connection string (required for any DB-touching path).
# A localhost/127.0.0.1 URL switches the app to the node-postgres driver so
# local development can run against a plain Postgres server.
DATABASE_URL="postgresql://user:password@host.neon.tech/blu_crm?sslmode=require"

# Better Auth — generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=""
# Canonical app URL (callbacks/redirects)
BETTER_AUTH_URL="http://localhost:3000"

# Initial password db:seed attaches to the three team accounts
# (andy/kurt/jess @blu.builders). The local default is blu-crm-dev for
# dev/E2E; ALWAYS set a strong value when seeding production, and have each
# person change it in Settings > Account after first sign-in.
# SEED_USER_PASSWORD=""

# Inlined into the client bundle at build time (auth client base URL)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Public base URL of the R2 bucket; unset = local-dev fallback behaviour
# NEXT_PUBLIC_R2_PUBLIC_URL=""

# Shared secret the email forwarding hop sends as a Bearer token to
# POST /api/intake/email (FR-3.3). Intake returns 503 while unset.
# EMAIL_INTAKE_TOKEN=""

# Public enquiry endpoint rate limit per IP per minute (default 5).
# Raised in local dev so parallel E2E projects don't trip it.
# ENQUIRY_RATE_LIMIT="5"

# E2E safety guard. The Playwright suite clears/sweeps data, so it refuses to
# run unless DATABASE_URL's host matches this value. Point it at a disposable
# test database (e.g. a Neon staging branch); production runs on a different
# endpoint, so its host will never match and can never be used for tests.
# E2E_DB_HOST="ep-your-staging-branch-pooler.ap-southeast-2.aws.neon.tech"

# AI assistant (FR-7 / M4). The assistant shows an offline state while the
# key is unset; the rest of the CRM is unaffected.
# ANTHROPIC_API_KEY=""
# Claude model id used by the assistant (defaults to claude-opus-4-8)
# AI_MODEL="claude-opus-4-8"
# Override the Anthropic API base URL — used by Playwright to point the
# assistant at a deterministic mock server. Leave unset normally.
# ANTHROPIC_BASE_URL=""

# Microsoft 365 (Entra ID) SSO — required once the Entra app is registered
# MICROSOFT_CLIENT_ID=""
# MICROSOFT_CLIENT_SECRET=""
# MICROSOFT_TENANT_ID=""
