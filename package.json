    "tsx": "^4.22.4",
    "typescript": "^5",
    "ultracite": "7.8.2",
    "wrangler": "^4.99.0"
  },
  "name": "blu-crm",
  "scripts": {
    "dev": "next dev",
    "build": "next build --webpack",
    "start": "next start",
    "preview": "rm -rf .next .open-next && opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "rm -rf .next .open-next && opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "db:push": "dotenv -e .env.local -- drizzle-kit push",
    "db:push:prod": "dotenv -e .env.production -- drizzle-kit push",
    "db:studio": "dotenv -e .env.local -- drizzle-kit studio",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "db:seed": "dotenv -e .env.local -- tsx src/db/seed.ts",
    "knowledge:import": "dotenv -e .env.local -- tsx src/db/knowledge-import.ts",
    "knowledge:import:prod": "dotenv -e .env.production -- tsx src/db/knowledge-import.ts",
    "ai:eval": "dotenv -e .env.local -- tsx evals/run.ts"
  },
  "version": "0.1.0",
  "private": true
}
