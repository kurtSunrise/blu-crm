  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@biomejs/biome": "2.4.16",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
